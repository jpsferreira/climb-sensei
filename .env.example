# ClimbSensei Environment Variables
# Copy this file to .env and fill in the values.

# REQUIRED — JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Database URL (default: SQLite for development)
DATABASE_URL=sqlite:///./climbsensei.db

# Google OAuth credentials (optional — leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth state secret (defaults to SECRET_KEY if not set)
# OAUTH_STATE_SECRET=

# OAuth redirect URL (must match Google Console config)
OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/google/callback

# JWT token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment: "production", "development", or "testing"
# AUTH_DISABLED only works in development/testing environments
ENVIRONMENT=development

# Set to "1" to disable authentication (development/testing ONLY)
# AUTH_DISABLED=

# CORS allowed origins (comma-separated, leave empty for same-origin only)
# CORS_ORIGINS=https://example.com,https://app.example.com

# Maximum upload file size in MB (default: 500)
MAX_UPLOAD_MB=500

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
